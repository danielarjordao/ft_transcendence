# Database
POSTGRES_USER=transcendence_user
POSTGRES_PASSWORD=transcendence_password
POSTGRES_DB=transcendence_db
DATABASE_URL=postgresql://transcendence_user:transcendence_password@db:5432/transcendence_db?schema=public

# Backend
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
API_URL=http://localhost:3000

# JWT
JWT_ACCESS_SECRET=change_this_access_secret
JWT_REFRESH_SECRET=change_this_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_2FA_SECRET=change_this_2fa_secret
JWT_2FA_EXPIRES_IN=5m

# Token hashing / encryption
AUTH_TOKEN_PEPPER=change_this_random_pepper
AUTH_ENCRYPTION_KEY=MDEyMzQ1Njc4OWFiY2RlZjAxMjM0NTY3ODlhYmNkZWY=

# Password reset
PASSWORD_RESET_EXPIRES_MINUTES=30
PASSWORD_RESET_FRONTEND_URL=http://localhost:5173/reset-password

# OAuth 42
FORTY_TWO_CLIENT_ID=your_42_client_id
FORTY_TWO_CLIENT_SECRET=your_42_client_secret
FORTY_TWO_CALLBACK_URL=http://localhost:3000/api/auth/42/callback

# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@fazelo.local

# HTTPS
HTTPS_ENABLED=false
HTTPS_KEY_PATH=
HTTPS_CERT_PATH=

# Frontend
VITE_API_URL=http://localhost:3000
